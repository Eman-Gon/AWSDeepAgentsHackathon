# ============================================================
# Commons — Shared Environment
# One file for frontend (Vite) + backend (Python/Edge Functions)
# Copy to .env and fill in values
# ============================================================

# --- Auth0 (shared) ---
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://commons-api
VITE_AUTH0_REDIRECT_URI=http://localhost:5173
VITE_AUTH0_CLAIMS_NAMESPACE=https://commons.app

# Backend-only Auth0 (Edge Functions / Python agent)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://commons-api
AUTH0_CLAIMS_NAMESPACE=https://commons.app

# --- SODA API (backend) ---
# Optional — higher rate limits. Register at https://data.sfgov.org
SODA_APP_TOKEN=

# --- Aerospike (backend) ---
AEROSPIKE_HOST=127.0.0.1
AEROSPIKE_PORT=3000
AEROSPIKE_NAMESPACE=commons

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key

# --- Overmind (LLM observability + optimization) ---
# Sign up at https://console.overmindlab.ai/ for API key
OVERMIND_API_KEY=ovr_...
OVERMIND_ENVIRONMENT=development

# --- TrueFoundry AI Gateway (optional) ---
# Routes LLM calls through TrueFoundry for cost tracking + observability
TRUEFOUNDRY_BASE_URL=https://your-domain.truefoundry.cloud/api/llm
TRUEFOUNDRY_API_KEY=tfy-...
TRUEFOUNDRY_MODEL=openai-main/gpt-4o
